// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Share {
  id          String  @id @default(uuid())
  textContent String?

  fileKey  String?
  fileId   String?
  fileName String?
  size     String?
  type     String?

  uploadedConfirmed Boolean? @default(false)

  codeHash  String?
  expiresAt DateTime?
  createdAt DateTime?
}
